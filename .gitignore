.DS_Store
**/.DS_Store

# Local agent/editor state
.claude/

# JavaScript dependencies and builds
node_modules/
**/node_modules/
dist/
**/dist/
dist-ts/
**/dist-ts/

# Python caches and builds
__pycache__/
**/__pycache__/
.pytest_cache/
.ruff_cache/
.venv/
*.pyc
*.egg-info/

# Rust/Kotlin/Swift build outputs
target/
**/target/
.gradle/
**/.gradle/
build/
**/build/
.build/
**/.build/
.swiftpm/
DerivedData/

# Local logs
*.log

# Demo-video render outputs (the .mp4 binaries are large; the
# compositions/ sources are what we track).
demo-video/renders/

# Conformance reports — CI regenerates these on every push to main.
# Keep the directory itself (via .gitkeep) so workflows can write here.
output/*
!output/.gitkeep
